{
  "name": "vfantv",
  "version": "0.1.6",
  "productName": "VfanTV",
  "description": "A free, source-available, non-commercial local media player with configurable content sources.",
  "main": "./out/main/index.js",
  "author": "VfanLee",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/vfanlee/VfanTV#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfanlee/VfanTV.git"
  },
  "bugs": {
    "url": "https://github.com/vfanlee/VfanTV/issues"
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build:app": "pnpm run typecheck && electron-vite build",
    "build": "pnpm run build:app && electron-builder",
    "build:dir": "pnpm run build:app && electron-builder --dir",
    "build:mac": "pnpm run build:app && electron-builder --mac",
    "build:win": "pnpm run build:app && electron-builder --win",
    "release": "pnpm run build:app && electron-builder --publish onTagOrDraft",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "logo:png": "node scripts/logo-to-png.cjs",
    "icons:generate": "node scripts/generate-app-icons.cjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xmldom/xmldom": "^0.8.13",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vidstack/react": "1.15.6",
    "@vitejs/plugin-react": "^5.1.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "hls.js": "^1.6.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "lucide-react": "^1.18.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.6.0",
    "react-router": "^7.17.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,html}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
