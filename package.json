{
  "name": "vfan-tv",
  "version": "0.7.0",
  "description": "一款免费开源、开箱即用、跨平台的桌面端影视聚合播放器。",
  "homepage": "https://github.com/vfanlee/vfan-tv#readme",
  "bugs": {
    "url": "https://github.com/vfanlee/vfan-tv/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfanlee/vfan-tv.git"
  },
  "license": "GPL-3.0",
  "author": "VfanLee",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "pnpm run typecheck && electron-vite build",
    "build:dir": "pnpm run build && electron-builder --dir",
    "build:mac": "pnpm run build && electron-builder --mac --publish never",
    "build:mac:arm64": "pnpm run build && electron-builder --mac --arm64 --publish never",
    "build:win": "pnpm run build && electron-builder --win --publish never",
    "build:win:arm64": "pnpm run build && electron-builder --win --arm64 --publish never",
    "build:win:x64": "pnpm run build && electron-builder --win --x64 --publish never",
    "db:generate": "drizzle-kit generate",
    "dev": "electron-vite dev",
    "format": "prettier --write .",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint --cache .",
    "prepare": "husky",
    "release": "pnpm run build && electron-builder --publish onTagOrDraft",
    "start": "electron-vite preview",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xmldom/xmldom": "^0.8.13",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.10.0",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "6.3.9",
    "file-type": "^22.0.1",
    "iptv-playlist-parser": "^0.15.2",
    "ms": "2.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "artplayer": "5.4.0",
    "artplayer-plugin-ambilight": "1.1.0",
    "artplayer-plugin-audio-track": "1.1.0",
    "artplayer-plugin-hls-control": "1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "39.2.6",
    "electron-builder": "26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "hls.js": "^1.6.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "lucide-react": "^1.18.0",
    "mpegts.js": "^1.8.0",
    "prettier": "^3.7.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.6.0",
    "react-router": "^7.17.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "zustand": "^5.0.14"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.12 <23",
    "pnpm": "11.11.0"
  }
}
